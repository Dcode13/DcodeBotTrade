# ---------------------------------------------------------------------------
# SECRET / ENV - salin ke file ".env" lalu isi. JANGAN commit file .env.
# ---------------------------------------------------------------------------

# MetaTrader 5
# Login akun (nomor login, password, server) TIDAK disimpan di sini.
# Masuk akun lewat Telegram: kirim /login lalu ikuti langkahnya.
# Path opsional ke terminal64.exe (kosongkan jika MT5 sudah berjalan)
MT5_PATH=

# Telegram
TELEGRAM_BOT_TOKEN=
OWNER_CHAT_ID=

# Modul fundamental / kalender berita (opsional)
NEWS_API_KEY=

# Gerbang eksekusi live:
#   false = alert-only (DEFAULT, aman) -> hitung & kirim sinyal, TIDAK kirim order
#   true  = izinkan eksekusi uang asli (masih butuh /confirm_live di Telegram)
EXECUTE=false
